{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ello",
  "version": "1.0.1",
  "identifier": "com.ello.dictation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ello",
        "width": 800,
        "height": 600,
        "decorations": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "overlay.html",
        "width": 320,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwQTA5QzlDRDlFNzM5RUEKUldUcU9lZlpuSnlnb055SE96ZXlTZGxvbEJaWkJQb3BTbXlJc3ZITG1IMWNBVURDMXZGYVUzYm4K",
      "endpoints": ["https://github.com/FadhilahAfif/Ello/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "uninstallerHeaderImage": "icons/nsis-header.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
